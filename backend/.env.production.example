# The platform may provide PORT automatically. SERVER_PORT overrides it when set.
# SERVER_PORT=8080

# Use a JDBC URL from Neon, Supabase, or another managed PostgreSQL provider.
DB_URL=jdbc:postgresql://database-host.example.com:5432/postgres?sslmode=require
DB_USERNAME=replace_with_database_user
DB_PASSWORD=replace_with_database_password
DB_POOL_SIZE=10
DB_MIN_IDLE=2

# Exact comma-separated frontend origins. Do not include trailing slashes.
CORS_ALLOWED_ORIGINS=https://portfolio.example.com

# Generate a unique secret with at least 32 random bytes.
JWT_SECRET=replace_with_a_long_random_production_secret
JWT_EXPIRATION=PT2H
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace_with_a_unique_strong_password
