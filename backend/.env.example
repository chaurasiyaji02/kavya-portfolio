SERVER_PORT=8080

DB_HOST=localhost
DB_PORT=5432
DB_NAME=kavya_portfolio
DB_USERNAME=portfolio_user
DB_PASSWORD=replace_with_a_secure_password
# Optional full JDBC URL. When set, this overrides DB_HOST, DB_PORT, and DB_NAME.
# DB_URL=jdbc:postgresql://localhost:5432/kavya_portfolio

DB_POOL_SIZE=10
DB_MIN_IDLE=2
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Use at least 32 random characters and rotate this value between environments.
JWT_SECRET=replace_with_a_long_random_secret_at_least_32_characters
JWT_EXPIRATION=PT2H
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace_with_a_strong_admin_password
